# Base da Delivery API do Ignite CMS (sem barra no final)
DELIVERY_API_URL="https://api.ignitecms.io/api/delivery"

# Token de delivery (cms_*) — gerado no painel. NUNCA exponha no client.
DELIVERY_API_TOKEN="cms_xxx"

# Tipo de conteúdo dos artigos na Delivery API
DELIVERY_POST_TYPE="post"

# URL pública do blog (usada em canonical, OG e sitemap)
SITE_URL="http://localhost:3005"
